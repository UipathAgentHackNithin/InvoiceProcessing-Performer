<Activity mc:Ignorable="sap sap2010" x:Class="ValidateInvoiceApproval" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib" xmlns:ui="http://schemas.uipath.com/workflow/activities" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <x:Members>
    <x:Property Name="in_TransactionItem" Type="InArgument(ui:QueueItem)" />
  </x:Members>
  <mva:VisualBasic.Settings>
    <x:Null />
  </mva:VisualBasic.Settings>
  <sap:VirtualizedContainerService.HintSize>600,500</sap:VirtualizedContainerService.HintSize>
  <sap2010:WorkflowViewState.IdRef>ValidateInvoiceApproval_1</sap2010:WorkflowViewState.IdRef>
  <TextExpression.NamespacesForImplementation>
    <scg:List x:TypeArguments="x:String" Capacity="10">
      <x:String>System</x:String>
      <x:String>System.Collections.Generic</x:String>
      <x:String>System.Linq</x:String>
      <x:String>UiPath.Core</x:String>
      <x:String>UiPath.Core.Activities</x:String>
    </scg:List>
  </TextExpression.NamespacesForImplementation>
  <TextExpression.ReferencesForImplementation>
    <scg:List x:TypeArguments="AssemblyReference" Capacity="10">
      <AssemblyReference>mscorlib</AssemblyReference>
      <AssemblyReference>System.Core</AssemblyReference>
      <AssemblyReference>System</AssemblyReference>
      <AssemblyReference>UiPath.System.Activities</AssemblyReference>
    </scg:List>
  </TextExpression.ReferencesForImplementation>
  <Sequence DisplayName="Validate Invoice Approval" sap:VirtualizedContainerService.HintSize="580,460" sap2010:WorkflowViewState.IdRef="Sequence_1">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="vendor" />
      <Variable x:TypeArguments="x:Decimal" Name="amount" />
      <Variable x:TypeArguments="x:Decimal" Name="approvalLimit" />
      <Variable x:TypeArguments="scg:Dictionary(x:String, x:Decimal)" Name="vendorApprovalLimits" />
    </Sequence.Variables>
    <sap:WorkflowViewStateService.ViewState>
      <scg:Dictionary x:TypeArguments="x:String, x:Object">
        <x:Boolean x:Key="IsExpanded">True</x:Boolean>
      </scg:Dictionary>
    </sap:WorkflowViewStateService.ViewState>

    <!-- Step 1: Extract vendor and amount from queue item -->
    <Assign DisplayName="Get Vendor" sap2010:WorkflowViewState.IdRef="Assign_1">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[vendor]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[If(in_TransactionItem.SpecificContent("Vendor") IsNot Nothing, in_TransactionItem.SpecificContent("Vendor").ToString, "")]</InArgument>
      </Assign.Value>
    </Assign>

    <Assign DisplayName="Get Amount" sap2010:WorkflowViewState.IdRef="Assign_2">
      <Assign.To>
        <OutArgument x:TypeArguments="x:Decimal">[amount]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:Decimal">[CDec(in_TransactionItem.SpecificContent("Amount").ToString)]</InArgument>
      </Assign.Value>
    </Assign>

    <!-- Step 2: Build vendor approval limits dictionary -->
    <!-- BUG: Only known vendors are in this dictionary. Unknown vendors fall through to FirstOrDefault() = 0D -->
    <Assign DisplayName="Build Approval Limits" sap2010:WorkflowViewState.IdRef="Assign_3">
      <Assign.To>
        <OutArgument x:TypeArguments="scg:Dictionary(x:String, x:Decimal)">[vendorApprovalLimits]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="scg:Dictionary(x:String, x:Decimal)">[New Dictionary(Of String, Decimal) From {{"Acme Corp", 10000D}, {"Global Supplies", 25000D}, {"Tech Partners", 5000D}}]</InArgument>
      </Assign.Value>
    </Assign>

    <!-- Step 3: LINQ lookup — BUG: StringComparison.OrdinalIgnoreCase is not a valid overload in VB LINQ Where -->
    <!-- FirstOrDefault() returns 0D when vendor not found, so approvalLimit = 0D for any unlisted vendor -->
    <Assign DisplayName="LINQ Lookup Approval Limit" sap2010:WorkflowViewState.IdRef="Assign_4">
      <Assign.To>
        <OutArgument x:TypeArguments="x:Decimal">[approvalLimit]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:Decimal">[vendorApprovalLimits.Where(Function(kv) kv.Key.Equals(vendor, StringComparison.OrdinalIgnoreCase)).Select(Function(kv) kv.Value).FirstOrDefault()]</InArgument>
      </Assign.Value>
    </Assign>

    <!-- Step 4: Check approval limit — always fails when approvalLimit = 0D -->
    <If Condition="[amount > approvalLimit]" DisplayName="Exceeds Approval Limit?" sap2010:WorkflowViewState.IdRef="If_1">
      <If.Then>
        <Throw DisplayName="Throw BusinessRuleException" sap2010:WorkflowViewState.IdRef="Throw_1"
               Exception="[New BusinessRuleException(&quot;[Invoice Processing] Vendor approval limit exceeded for invoice &quot; + If(in_TransactionItem.SpecificContent(&quot;InvoiceNumber&quot;) IsNot Nothing, in_TransactionItem.SpecificContent(&quot;InvoiceNumber&quot;).ToString, &quot;UNKNOWN&quot;) + &quot; | Vendor: &quot; + vendor + &quot; | Amount: $&quot; + amount.ToString(&quot;F2&quot;) + &quot; | Approval limit: $&quot; + approvalLimit.ToString(&quot;F2&quot;) + &quot; | Note: vendor may not be registered in the approval limits configuration — please review or escalate to Finance team for manual approval.&quot;)]" />
      </If.Then>
    </If>

  </Sequence>
</Activity>
